# QA Search Bot - Environment Configuration

# API Keys (Required for LLM functionality)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Default Model (llama-3.1-70b-versatile, gpt-4o, etc.)
DEFAULT_MODEL=llama-3.1-70b-versatile

# ChromaDB Settings
CHROMA_PERSIST_DIR=./data/chroma

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# RAG Settings
MAX_CONTEXT_TOKENS=8000
TOP_K_CHUNKS=10

# Server Settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Data Paths
CSV_DATA_PATH=/Users/anirudhkapruwan/AI_Training/Antigravity/RAG:Advance_RAG/data/uploads/testcases_vwo.csv
PDF_DATA_PATH=/Users/anirudhkapruwan/AI_Training/Antigravity/Live_Class/Chapter_08_RAG/Basic_RAG_EXPLAIN/data/Product Requirements Document_VWO.pdf
GITHUB_REPO_URL=https://github.com/PramodDutta/AdvanceSeleniumFrameworkTTA